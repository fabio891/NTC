      ],
      "id": "c6ac5161-54b5-4edc-8f5b-121d3ee8cddd",
      "name": "Chamar Processador Inteligente (WF2)"
    },
    {
      "parameters": {
        "jsCode": "// Busca os dados do nó 'Agrupar e Combinar Mensagens' (que tem os ids)\nconst dadosOriginais = $('Agrupar e Combinar Mensagens').first().json;\nconst ids = dadosOriginais.ids;\n\nif (!ids || ids.length === 0) {\n  return [];\n}\n\n// Gera um item para cada id, com o campo 'processado' = \"true\"\nreturn ids.map(id => ({\n  json: {\n    id: id,\n    processado: \"true\"\n  }\n}));"
      },
