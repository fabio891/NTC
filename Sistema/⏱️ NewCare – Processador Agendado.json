      "id": "65febb32-0ce1-4d67-845a-04208b597ee7",
      "name": "Buscar Mensagens Pendentes"
    },
    {
      "parameters": {
        "jsCode": "const TEMPO_MAX_INTERVALO_MS = 60000; // 60 segundos – ajuste conforme necessário\n\n// Busca todas as mensagens pendentes (entrada do nó Data Table)\nconst todas = $input.all().map(item => item.json);\nif (todas.length === 0) return [];\n\n// Agrupar por remetente\nconst porRemetente = new Map();\nfor (const msg of todas) {\n  const rem = msg.remetente;\n  if (!porRemetente.has(rem)) porRemetente.set(rem, []);\n  porRemetente.get(rem).push(msg);\n}\n\nconst lotes = [];\nconst agora = new Date();\n\nfor (const [rem, msgs] of porRemetente) {\n  // Ordenar por timestamp (crescente)\n  msgs.sort((a, b) => new Date(a.timestamp) - new Date(b.timestamp));\n\n  // Última mensagem do remetente\n  const ultimaMsg = msgs[msgs.length - 1];\n  const tempoUltima = new Date(ultimaMsg.timestamp);\n  const idade = agora - tempoUltima;\n  \n  // Se a última mensagem tem menos de 60 segundos, aguardar próximo ciclo\n  if (idade < TEMPO_MAX_INTERVALO_MS) {\n    continue;\n  }\n\n  // --- Processar TODAS as mensagens deste remetente (grupo único) ---\n  const textos = [];\n  const textos_pdf = [];\n  let anexos = [];       // Acumula todos os anexos (imagens, PDFs, etc.)\n  const ids = [];\n  const message_raw_list = [];\n  let canal = '';\n  let assunto = '';\n\n  for (const msg of msgs) {\n    canal = msg.canal;\n    assunto = msg.assunto || '';\n    if (msg.texto) textos.push(msg.texto);\n    if (msg.texto_pdf) textos_pdf.push(msg.texto_pdf);\n    \n    // Acumular anexos (importante para múltiplas imagens)\n    if (msg.anexos && msg.anexos !== '[]') {\n      try {\n        let anexosMsg = typeof msg.anexos === 'string' ? JSON.parse(msg.anexos) : msg.anexos;\n        if (!Array.isArray(anexosMsg)) anexosMsg = [anexosMsg];\n        anexos.push(...anexosMsg);\n      } catch (e) {\n        console.error('Erro ao parsear anexos da mensagem', msg.id, e);\n      }\n    }\n    \n    if (msg.id) ids.push(msg.id);\n    if (msg.message_raw) message_raw_list.push(msg.message_raw);\n  }\n\n  const textoCompleto = textos.join('\\n\\n').trim();\n  const textoPdfCompleto = textos_pdf.join('\\n\\n').trim();\n\n  lotes.push({\n    json: {\n      canal,\n      remetente: rem,\n      assunto,\n      texto: textoCompleto,\n      texto_pdf: textoPdfCompleto,\n      anexos: JSON.stringify(anexos),   // Contém todos os anexos do remetente\n      message_raw: JSON.stringify(message_raw_list),\n      timestamp: new Date().toISOString(),\n      ids   // Agora contém TODOS os ids do remetente\n    }\n  });\n}\n\n// Log para depuração (opcional – pode remover depois)\nconsole.log(`Total de lotes gerados: ${lotes.length}`);\nif (lotes.length > 0) {\n  console.log(`Primeiro lote - remetente: ${lotes[0].json.remetente}, anexos: ${lotes[0].json.anexos}`);\n}\n\nreturn lotes;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -752,
